{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taskplan-pro.operation-build-manifest/v1",
  "title": "TASKPLAN-PRO Operation Map Build Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "builder_version", "graph", "concept", "outputs", "locales", "checks"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "builder_version": {"type": "string", "minLength": 1},
    "graph": {"$ref": "#/$defs/artifact"},
    "concept": {"type": ["object", "null"]},
    "outputs": {"type": "object", "minProperties": 3, "additionalProperties": {"$ref": "#/$defs/artifact"}},
    "locales": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
    "checks": {"type": "object", "additionalProperties": {"enum": ["passed", "not_run", "not_applicable"]}}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
