{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taskplan-pro.operation-locale-catalog/v1",
  "title": "TASKPLAN-PRO Operation Map Locale Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "graph_id", "graph_version", "graph_sha256", "source_locale", "locales", "translation_provenance", "entries"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "graph_id": {"type": "string", "minLength": 1},
    "graph_version": {"type": "string", "minLength": 1},
    "graph_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_locale": {"enum": ["ru", "en", "es", "fr", "de"]},
    "locales": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["ru", "en", "es", "fr", "de"]}},
    "translation_provenance": {"type": "object"},
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "translations"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "translations": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}}
        }
      }
    }
  }
}
